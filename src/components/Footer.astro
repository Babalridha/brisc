---
import Icon from './Icon.astro';

const LOGO_URL = "https://brisc.babalridha.com/wp-content/uploads/2018/03/BRI_Logo-1.png";
---

<footer class="bg-[#dcd6be] text-[#134503] pt-20 pb-10 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16">
      <div class="col-span-1 md:col-span-1">
        <div class="flex items-center gap-3 mb-6">
          <img src={LOGO_URL} alt="Logo" class="h-10 w-auto rounded-lg" />
          <span class="text-2xl font-bold tracking-tight">Bab al-Ridha</span>
        </div>
        <p class="text-[#134503]/80 text-sm leading-relaxed mb-6">
          A premier gateway to intensive Islamic education, fostering clarity of mind and vision for the modern world. Host to hundreds of seekers globally in the heart of Qom.
        </p>
        <div class="flex gap-4">
          <a href="https://instagram.com/babalridha" target="_blank" rel="noopener noreferrer" class="hover:opacity-70 transition-opacity">
            <Icon name="Instagram" size={20} />
          </a>
          <a href="https://youtube.com/@babalridha" target="_blank" rel="noopener noreferrer" class="hover:opacity-70 transition-opacity">
            <Icon name="Youtube" size={20} />
          </a>
          <a href="https://facebook.com/babalridha" target="_blank" rel="noopener noreferrer" class="hover:opacity-70 transition-opacity">
            <Icon name="Facebook" size={20} />
          </a>
          <a href="https://wa.me/989337254681" target="_blank" rel="noopener noreferrer" class="hover:opacity-70 transition-opacity">
            <Icon name="MessageCircle" size={20} />
          </a>
          <a href="mailto:info@babalridha.com" class="hover:opacity-70 transition-opacity">
            <Icon name="Mail" size={20} />
          </a>
        </div>
      </div>

      <div>
        <h4 class="text-[#134503] font-extrabold uppercase tracking-widest text-sm mb-6 underline decoration-[#134503]/20 underline-offset-8">Navigation</h4>
        <ul class="space-y-4 text-sm font-medium text-[#134503]/70">
          <li><a href="/about" class="hover:text-[#134503]">About</a></li>
          <li><a href="/curriculum" class="hover:text-[#134503]">Curriculum</a></li>
          <li><a href="/testimonials" class="hover:text-[#134503]">Testimonials</a></li>
          <li><a href="/gallery" class="hover:text-[#134503]">Gallery</a></li>
          <li><a href="/faq" class="hover:text-[#134503]">FAQs</a></li>
          <li><a href="/apply" class="hover:text-[#134503]">Apply Now</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-[#134503] font-extrabold uppercase tracking-widest text-sm mb-6 underline decoration-[#134503]/20 underline-offset-8">Connect</h4>
        <ul class="space-y-4 text-sm font-medium text-[#134503]/70">
          <li class="flex items-center gap-2"><Icon name="MapPin" size={16} /> Qom, Islamic Republic of Iran</li>
          <li class="flex items-center gap-2 font-bold"><Icon name="Phone" size={16} /> Contact Regional Reps</li>
          <li class="flex items-center gap-2 hover:text-[#134503] transition-colors">
            <a href="https://wa.me/989337254681" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2">
              <Icon name="MessageCircle" size={16} /> WhatsApp Inquiry
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-[#134503]/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-[10px] uppercase tracking-widest text-[#134503]/40 font-bold">
      <p>© 2026 Bab al-Ridha Intensive. All Rights Reserved.</p>
    </div>
  </div>
</footer>
