---
import Layout from '../components/Layout.astro';
import Icon from '../components/Icon.astro';
import { Image } from 'astro:assets';
import { AIMS, WELCOME_PILLARS, CURRICULUM_SECTIONS } from '../constants';

import hero1Img from '../assets/images/Brisc-13-4web.png';
import hero2Img from '../assets/images/BRisc-6-collage.png';

const HERO_IMAGES = [hero1Img, hero2Img];
---

<Layout title="Bab al-Ridha | Intensive Short Course">
  <div class="bg-[#fcfbf7]">
    
    <!-- Hero Section -->
    <section id="hero" class="relative h-[95vh] flex items-center justify-center overflow-hidden m-4 rounded-[2.5rem] shadow-2xl">
      <!-- Slider Background -->
      <div class="absolute inset-0 z-0">
        {HERO_IMAGES.map((img, idx) => (
          <div
            data-slide-index={idx}
            class={`absolute inset-0 transition-all duration-1000 ease-in-out ${
              idx === 0 ? 'opacity-100 scale-100' : 'opacity-0 scale-110'
            }`}
          >
            <Image src={img} class="w-full h-full object-cover" alt={`Bab al-Ridha Slide ${idx + 1}`} />
          </div>
        ))}
        {/* Overlay Layers */}
        <div class="absolute inset-0 bg-black/50"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-[#134503]/60 to-transparent"></div>
      </div>
      
      <!-- Controls -->
      <button 
        id="hero-prev"
        class="absolute left-8 z-20 p-3 rounded-full border border-white/20 text-white hover:bg-white/10 transition-colors hidden md:block"
        aria-label="Previous Slide"
      >
        <Icon name="ChevronLeft" size={24} />
      </button>
      <button 
        id="hero-next"
        class="absolute right-8 z-20 p-3 rounded-full border border-white/20 text-white hover:bg-white/10 transition-colors hidden md:block"
        aria-label="Next Slide"
      >
        <Icon name="ChevronRight" size={24} />
      </button>

      <!-- Content -->
      <div class="relative z-10 text-left w-full max-w-7xl mx-auto px-8 md:px-16 animate-in fade-in slide-in-from-left-8 duration-1000">
        <div class="max-w-4xl">
          <div class="w-16 h-1.5 bg-[#dcd6be] mb-8 rounded-full"></div>
          <h1 class="text-white font-serif text-5xl md:text-8xl mb-8 leading-tight drop-shadow-lg font-bold">
            Bab al-Ridha<br />
            <span class="italic text-[#dcd6be]/90">Intensive Short Course</span>
          </h1>
          <p class="text-[#dcd6be] text-xl md:text-3xl font-medium tracking-wide mb-12 drop-shadow-md">
            Learn to see the world through an Islamic lens.
          </p>
          <div class="flex flex-col sm:flex-row gap-6">
            <a href="/about" class="bg-[#dcd6be] text-[#134503] px-12 py-5 rounded-full font-bold uppercase tracking-widest hover:bg-white hover:scale-105 transition-all shadow-xl flex items-center justify-center gap-3">
              Explore the Journey <Icon name="ArrowRight" size={20} />
            </a>
            <a href="/curriculum" class="border-2 border-white/40 text-white px-12 py-5 rounded-full font-bold uppercase tracking-widest hover:bg-white/10 transition-all backdrop-blur-md flex items-center justify-center">
              View Curriculum
            </a>
          </div>
        </div>
      </div>

      <!-- Slide Indicators -->
      <div class="absolute bottom-24 left-1/2 -translate-x-1/2 flex gap-4 z-20">
        {HERO_IMAGES.map((_, idx) => (
          <button
            data-indicator-index={idx}
            class={`h-1.5 rounded-full transition-all duration-500 ${
              idx === 0 ? 'w-12 bg-[#dcd6be]' : 'w-4 bg-white/30'
            }`}
            aria-label={`Go to slide ${idx + 1}`}
          />
        ))}
      </div>
    </section>

    <!-- Countdown Timer -->
    <div id="countdown-timer" class="relative z-30 max-w-4xl mx-auto -mt-16 px-4">
      <div class="bg-[#dcd6be] rounded-3xl md:rounded-full shadow-2xl p-6 md:p-8 border border-white/20 backdrop-blur-sm flex flex-col md:flex-row items-center justify-between gap-6 md:gap-0">
        <div class="flex flex-col items-center md:items-start md:pl-8">
          <span class="text-[10px] uppercase font-black text-[#134503] tracking-[0.3em] mb-1">Registration</span>
          <h3 class="text-xl font-serif italic font-bold text-[#134503]">Closes In:</h3>
        </div>
        <div class="flex divide-x divide-[#134503]/10">
          <div class="flex flex-col items-center px-4 md:px-8">
            <span id="timer-days" class="text-3xl md:text-5xl font-black text-[#134503] tracking-tighter">00</span>
            <span class="text-[10px] uppercase font-black text-[#134503]/40 tracking-widest">Days</span>
          </div>
          <div class="flex flex-col items-center px-4 md:px-8">
            <span id="timer-hours" class="text-3xl md:text-5xl font-black text-[#134503] tracking-tighter">00</span>
            <span class="text-[10px] uppercase font-black text-[#134503]/40 tracking-widest">Hrs</span>
          </div>
          <div class="flex flex-col items-center px-4 md:px-8">
            <span id="timer-minutes" class="text-3xl md:text-5xl font-black text-[#134503] tracking-tighter">00</span>
            <span class="text-[10px] uppercase font-black text-[#134503]/40 tracking-widest">Mins</span>
          </div>
          <div class="flex flex-col items-center px-4 md:px-8">
            <span id="timer-seconds" class="text-3xl md:text-5xl font-black text-[#134503] tracking-tighter">00</span>
            <span class="text-[10px] uppercase font-black text-[#134503]/40 tracking-widest">Secs</span>
          </div>
        </div>
        <a href="/apply" class="bg-[#134503] text-[#dcd6be] px-10 py-4 rounded-full font-bold uppercase text-[10px] tracking-[0.3em] hover:scale-105 transition-all shadow-xl md:mr-4">
          Apply Now
        </a>
      </div>
    </div>

    <!-- Welcome Section -->
    <section class="py-24 pt-32 bg-[#fcfbf7]">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <h2 class="text-[#134503] font-serif text-4xl md:text-6xl mb-8 font-bold italic">Welcome to BRisc!</h2>
        <p class="text-gray-600 text-lg md:text-2xl leading-relaxed font-medium mb-16 max-w-5xl mx-auto">
          The Bab al-Ridha intensive short course (BRisc) is a three-week Islamic course held in December in the holy city of Qom, Iran.
          Organised by students of the Hawza, the course provides the Muslim youth with essential Islamic knowledge, vision, and practical skills.
        </p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {WELCOME_PILLARS.map((pillar) => (
            <div class="relative group h-80 rounded-[2.5rem] overflow-hidden shadow-xl hover:-translate-y-2 transition-all">
              <Image src={pillar.image} class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt={pillar.title} />
              <div class="absolute inset-0 bg-gradient-to-t from-[#134503]/90 via-[#134503]/20 to-transparent"></div>
              <div class="absolute bottom-8 left-0 right-0 px-6">
                <h3 class="text-[#dcd6be] font-bold text-xl uppercase tracking-tighter leading-tight">{pillar.title}</h3>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Aims Section -->
    <section class="py-24 bg-[#134503]">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-20">
          <span class="text-[#dcd6be] uppercase tracking-[0.4em] text-[10px] font-extrabold block mb-4">Core Vision</span>
          <h2 class="text-[#dcd6be] font-serif text-4xl md:text-6xl italic font-bold">Aims of the Course</h2>
          <div class="w-20 h-1.5 bg-[#dcd6be] mx-auto mt-8 rounded-full"></div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
          {AIMS.map((aim) => (
            <div class="relative group h-[28rem] rounded-[3.5rem] overflow-hidden shadow-2xl">
              <Image src={aim.image} class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:scale-105 transition-all duration-1000" alt={aim.title} />
              <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-[#134503]/40 to-[#134503]"></div>
              <div class="absolute inset-0 p-12 flex flex-col justify-end text-left">
                <div class="text-[#dcd6be] text-[10px] font-extrabold uppercase tracking-widest mb-4">Goal 0{aim.id}</div>
                <h3 class="text-2xl font-bold text-white mb-4 uppercase tracking-tight">{aim.title}</h3>
                <p class="text-white/70 text-sm font-medium leading-relaxed group-hover:text-white transition-colors">{aim.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Curriculum Brief -->
    <section class="py-24 bg-[#fcfbf7]">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex flex-col md:flex-row items-end justify-between mb-16 gap-8">
          <div class="text-left">
            <h2 class="text-[#134503] font-serif text-4xl md:text-6xl italic font-bold mb-4">What you'll experience</h2>
            <p class="text-gray-500 font-medium text-lg">A brief look at our 3-week immersive curriculum.</p>
          </div>
          <a href="/curriculum" class="bg-[#134503] text-[#dcd6be] px-10 py-4 rounded-full font-bold uppercase text-xs tracking-widest shadow-lg">View Full Details</a>
        </div>
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          {CURRICULUM_SECTIONS.slice(0, 4).map((item) => (
             <div class="flex gap-8 p-10 bg-white rounded-[3rem] border border-[#dcd6be]/20 shadow-xl shadow-[#dcd6be]/5">
                <div class="hidden sm:block w-32 h-32 rounded-[2rem] overflow-hidden shrink-0 shadow-lg">
                  <Image src={item.image} class="w-full h-full object-cover" alt={item.title} />
                </div>
                <div>
                   <h3 class="text-[#134503] font-bold text-xl uppercase tracking-tighter mb-4">{item.title}</h3>
                   <p class="text-gray-500 text-sm leading-relaxed font-medium line-clamp-3">{item.desc}</p>
                </div>
             </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="bg-[#134503] py-24 m-4 rounded-[4rem] text-[#dcd6be] border border-white/5">
      <div class="max-w-7xl mx-auto px-4">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-12 text-center">
          {[
            { value: '50+', label: 'Hours of Classes', icon: 'BookOpen' },
            { value: '6', label: 'Field Trips', icon: 'Map' },
            { value: '4', label: 'Scholar Visits', icon: 'Star' },
            { value: '2', label: 'Sacred Cities', icon: 'Activity' }
          ].map((stat) => (
            <div class="flex flex-col items-center group">
              <div class="bg-white/5 p-8 rounded-full mb-8 group-hover:scale-110 transition-transform shadow-xl border border-white/10">
                 <Icon name={stat.icon} class="text-[#dcd6be]" size={36} />
              </div>
              <span class="text-white text-6xl font-extrabold mb-4 block tracking-tighter">{stat.value}</span>
              <span class="text-[#dcd6be] text-[10px] uppercase tracking-[0.4em] font-extrabold">{stat.label}</span>
            </div>
          ))}
        </div>
        <div class="mt-20 text-center">
          <div class="inline-block px-10 py-4 bg-[#dcd6be]/10 rounded-full border border-white/10">
             <span class="text-[#dcd6be] font-extrabold text-xl italic tracking-widest uppercase">13 Years of Academic Excellence</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="py-24 m-4 bg-[#dcd6be] rounded-[4rem] shadow-inner overflow-hidden">
      <div class="max-w-7xl mx-auto px-8 grid grid-cols-1 md:grid-cols-2 gap-20 items-center">
         <div class="text-left">
            <span class="text-[#134503]/50 uppercase tracking-[0.4em] text-[10px] font-extrabold block mb-6">Contact Us</span>
            <h2 class="text-5xl md:text-7xl font-serif mb-10 leading-tight italic font-bold text-[#134503]">Have questions?</h2>
            <p class="text-[#134503]/70 text-lg font-medium leading-relaxed mb-10 italic">
               Whether you're a potential participant or a curious community member, we're here to help you understand the BRisc journey better.
            </p>
            <div class="space-y-4">
               <div class="flex items-center gap-4 text-[#134503]">
                  <div class="w-10 h-10 bg-[#134503] rounded-2xl flex items-center justify-center text-[#dcd6be]"><Icon name="Mail" size={18}/></div>
                  <span class="font-bold text-sm tracking-widest">INFO@BABALRIDHA.COM</span>
               </div>
            </div>
         </div>
         <div class="bg-white p-10 md:p-14 rounded-[3rem] shadow-2xl">
            <form class="space-y-6" onsubmit="event.preventDefault(); alert('Message sending is a mock action!');">
               <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <input placeholder="Name" class="w-full px-6 py-4 bg-[#fcfbf7] rounded-2xl border-none focus:ring-2 focus:ring-[#134503] outline-none text-sm font-medium" />
                  <input placeholder="Email" class="w-full px-6 py-4 bg-[#fcfbf7] rounded-2xl border-none focus:ring-2 focus:ring-[#134503] outline-none text-sm font-medium" />
               </div>
               <textarea placeholder="Your Message" rows={4} class="w-full px-6 py-4 bg-[#fcfbf7] rounded-3xl border-none focus:ring-2 focus:ring-[#134503] outline-none text-sm font-medium resize-none"></textarea>
               <button type="submit" class="w-full bg-[#134503] text-[#dcd6be] py-5 rounded-full font-bold uppercase tracking-[0.2em] shadow-xl hover:scale-105 transition-all flex items-center justify-center gap-3">
                  Send Message <Icon name="Send" size={18} />
               </button>
            </form>
         </div>
      </div>
    </section>

  </div>
</Layout>

<script>
  // --- Slideshow Logic ---
  const slides = document.querySelectorAll('[data-slide-index]');
  const indicators = document.querySelectorAll('[data-indicator-index]');
  const nextBtn = document.getElementById('hero-next');
  const prevBtn = document.getElementById('hero-prev');
  let currentSlide = 0;
  const totalSlides = slides.length;
  let intervalId: any;

  function showSlide(index: number) {
    slides.forEach((slide, idx) => {
      if (idx === index) {
        slide.classList.remove('opacity-0', 'scale-110');
        slide.classList.add('opacity-100', 'scale-100');
      } else {
        slide.classList.remove('opacity-100', 'scale-100');
        slide.classList.add('opacity-0', 'scale-110');
      }
    });

    indicators.forEach((indicator, idx) => {
      if (idx === index) {
        indicator.classList.remove('w-4', 'bg-white/30');
        indicator.classList.add('w-12', 'bg-[#dcd6be]');
      } else {
        indicator.classList.remove('w-12', 'bg-[#dcd6be]');
        indicator.classList.add('w-4', 'bg-white/30');
      }
    });
    currentSlide = index;
  }

  function nextSlide() {
    showSlide((currentSlide + 1) % totalSlides);
  }

  function prevSlide() {
    showSlide((currentSlide - 1 + totalSlides) % totalSlides);
  }

  function startAutoplay() {
    intervalId = setInterval(nextSlide, 6000);
  }

  function resetAutoplay() {
    clearInterval(intervalId);
    startAutoplay();
  }

  if (nextBtn && prevBtn) {
    nextBtn.addEventListener('click', () => {
      nextSlide();
      resetAutoplay();
    });
    prevBtn.addEventListener('click', () => {
      prevSlide();
      resetAutoplay();
    });
  }

  indicators.forEach((indicator, idx) => {
    indicator.addEventListener('click', () => {
      showSlide(idx);
      resetAutoplay();
    });
  });

  startAutoplay();


  // --- Countdown Timer Logic ---
  const daysEl = document.getElementById('timer-days');
  const hoursEl = document.getElementById('timer-hours');
  const minsEl = document.getElementById('timer-minutes');
  const secsEl = document.getElementById('timer-seconds');

  if (daysEl && hoursEl && minsEl && secsEl) {
    const targetDate = new Date();
    targetDate.setDate(targetDate.getDate() + 45);
    const targetTime = targetDate.getTime();

    const updateTimer = () => {
      const now = new Date().getTime();
      const distance = targetTime - now;

      if (distance < 0) {
        clearInterval(timerInterval);
        daysEl.textContent = '00';
        hoursEl.textContent = '00';
        minsEl.textContent = '00';
        secsEl.textContent = '00';
        return;
      }

      const days = Math.floor(distance / (1000 * 60 * 60 * 24));
      const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((distance % (1000 * 60)) / 1000);

      daysEl.textContent = days.toString().padStart(2, '0');
      hoursEl.textContent = hours.toString().padStart(2, '0');
      minsEl.textContent = minutes.toString().padStart(2, '0');
      secsEl.textContent = seconds.toString().padStart(2, '0');
    };

    updateTimer();
    const timerInterval = setInterval(updateTimer, 1000);
  }
</script>
