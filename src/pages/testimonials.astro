---
import Layout from '../components/Layout.astro';
import Icon from '../components/Icon.astro';

const allTestimonials = [
  { name: "R. D.", loc: "India", text: "This course will bring you closer to the truth, know your surroundings, and help you understand yourself" },
  { name: "M. S.", loc: "South Africa", text: "BRisc has helped me in following the path of Allah (SWT). It has made me confident that my worldview is based on reality. It will definitely quench your thirst for knowledge and questions that you have regarding your purpose." },
  { name: "M. K.", loc: "South Africa", text: "The course exceeded all my expectations. It’s not only packed with lots of information but also lots of fun activities and trips that balance things out perfectly. Best of all, you get to meet new people and mentors who will be friends for life now!!" },
  { name: "H. N.", loc: "UAE", text: "I’d encourage, anyone interested in learning not only religion but how to have a good outlook on life, to definitely join this course if they can. The learning here is much better than at local centres as the approach is focused towards a more mature audience." },
  { name: "A. G.", loc: "Canada", text: "Taking this course is the best decision I’ve made in my life, the knowledge, experience, life long friendships, love, and the change it brought in me doesn’t compare to anything else." },
  { name: "K. S.", loc: "Tanzania", text: "BRisc is honestly a life changing course, it caters for everything you’d want. It’s a great way to spend your holidays because you will visit so many different places." },
  { name: "S. M.", loc: "Kenya", text: "Has been life changing for me. It brought a whole new perspective of Islam – opened my eyes. lifted the veils. cleared my doubts. taught me new things." },
  { name: "A. B.", loc: "Tanzania", text: "I came with high expectations and it fulfilled every one and more. This course has changed my outlook on life and I know I’ll come back a changed person." },
  { name: "S. M.", loc: "Tanzania", text: "Bab al Ridha gave me a new life. It made me positive that I won’t go back home as the same person I was when I came." },
  { name: "R", loc: "Toronto", text: "It’s not a course to give you just a bunch of Hawza knowledge. More, it’ll help you prepare yourself in a way you can’t do alone, help you see the world through Islam." },
  { name: "F. D.", loc: "Tanzania", text: "I have never been more grateful to Allah than I am now for giving me this chance. It has opened my eyes to so many things that I’ve been in the dark about for so long." },
  { name: "Z. P.", loc: "Tanzania", text: "The intensive course has given me an overall view and a vision to strengthen my personality and responsibilities as a Muslim." },
  { name: "M. R.", loc: "Tanzania", text: "Bab al Ridha has been more of an experience rather than just a camp. I have made irreplaceable friends, visited amazing places and learnt new things but most of all I have become part of a growing family." }
];
---

<Layout title="Testimonials | Bab al-Ridha Intensive">
  <div class="pt-32 pb-24 bg-[#fcfbf7]">
    <section class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-24">
        <div class="inline-block bg-[#dcd6be]/30 text-[#134503] px-8 py-2 text-[10px] font-extrabold uppercase tracking-[0.4em] mb-8 rounded-full border border-[#dcd6be]/40 shadow-sm">
          Testimonials
        </div>
        <h1 class="text-6xl md:text-8xl font-serif text-[#134503] mb-8 font-bold italic">What previous participants say...</h1>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-24 overflow-hidden">
        {allTestimonials.map((t, i) => {
          let animClass = '';
          if (i % 3 === 0) {
            animClass = '-translate-x-16 opacity-0';
          } else if (i % 3 === 1) {
            animClass = 'translate-y-16 opacity-0';
          } else {
            animClass = 'translate-x-16 opacity-0';
          }
          return (
            <div 
              data-testimonial-card
              class={`bg-white p-10 rounded-[3.5rem] border border-[#dcd6be]/15 shadow-xl flex flex-col justify-between hover:-translate-y-2 hover:shadow-2xl transition-all duration-1000 transform text-left ${animClass}`}
            >
              <div>
                <div class="flex items-center gap-5 mb-8">
                   <div class="w-14 h-14 rounded-2xl bg-[#dcd6be]/20 flex items-center justify-center text-[#134503] font-bold text-xl shadow-inner">
                     {t.name[0]}
                   </div>
                   <div>
                     <h4 class="text-[#134503] font-extrabold uppercase text-[10px] tracking-[0.3em] mb-1">{t.name}</h4>
                     <span class="text-[#dcd6be] text-[10px] uppercase tracking-[0.3em] font-extrabold">{t.loc}</span>
                   </div>
                </div>
                <Icon name="Quote" class="text-[#dcd6be]/30 mb-6" size={40} />
                <p class="text-[#134503] font-serif text-lg italic font-bold leading-relaxed mb-8">"{t.text}"</p>
              </div>
              <div class="pt-6 border-t border-[#dcd6be]/10">
                 <span class="text-[10px] uppercase font-extrabold text-[#dcd6be] tracking-[0.4em] block mb-2">Participant Feedback</span>
                 <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">Bab al-Ridha Alumnus</p>
              </div>
            </div>
          );
        })}
      </div>
    </section>
  </div>
</Layout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.remove('-translate-x-16', 'translate-y-16', 'translate-x-16', 'opacity-0');
        entry.target.classList.add('translate-x-0', 'translate-y-0', 'opacity-100');
        observer.unobserve(entry.target);
      }
    });
  }, {
    threshold: 0.05,
    rootMargin: '0px 0px -50px 0px'
  });

  document.querySelectorAll('[data-testimonial-card]').forEach((card) => {
    observer.observe(card);
  });
</script>
